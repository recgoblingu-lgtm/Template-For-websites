<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contact</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,Helvetica,sans-serif;
}

body{
    background:#0d1117;
    color:white;
}

header{
    position:sticky;
    top:0;
    background:#161b22;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 8%;
    z-index:100;
}

.logo{
    font-size:28px;
    font-weight:bold;
    color:#58a6ff;
}

nav{
    display:flex;
    gap:20px;
}

nav a{
    color:white;
    text-decoration:none;
    transition:.3s;
}

nav a:hover{
    color:#58a6ff;
}

.container{
    max-width:900px;
    margin:auto;
    padding:80px 20px;
}

h1{
    font-size:50px;
    margin-bottom:15px;
}

.subtitle{
    color:#b5b5b5;
    margin-bottom:40px;
}

.contact-card{
    background:#161b22;
    border-radius:12px;
    padding:30px;
    margin-bottom:25px;
}

.contact-card h2{
    color:#58a6ff;
    margin-bottom:15px;
}

input,
textarea{
    width:100%;
    padding:15px;
    margin-top:10px;
    margin-bottom:20px;
    background:#0d1117;
    color:white;
    border:1px solid #333;
    border-radius:8px;
    font-size:16px;
}

textarea{
    min-height:150px;
    resize:vertical;
}

button{
    background:#58a6ff;
    color:white;
    border:none;
    padding:14px 30px;
    border-radius:8px;
    cursor:pointer;
    font-size:16px;
}

button:hover{
    opacity:.85;
}

.info{
    line-height:2;
}

footer{
    text-align:center;
    padding:40px;
    background:#161b22;
    color:#888;
    margin-top:60px;
}
</style>

</head>

<body>

<header>

<div class="logo">
LOGO
</div>

<nav>
<a href="index.html">Home</a>
<a href="features.html">Features</a>
<a href="downloads.html">Downloads</a>
<a href="news.html">News</a>
<a href="discord.html">Discord</a>
<a href="contact.html">Contact</a>
</nav>

</header>

<div class="container">

<h1>Contact Us</h1>

<p class="subtitle">
Need help or have a question? We'd love to hear from you.
</p>

<div class="contact-card">

<h2>Send a Message</h2>

<form>

<input
type="text"
placeholder="Your Name"
required>

<input
type="email"
placeholder="Your Email"
required>

<textarea
placeholder="Your Message"
required></textarea>

<button type="submit">
Send Message
</button>

</form>

</div>

<div class="contact-card">

<h2>Contact Information</h2>

<div class="info">

<p>📧 Email: your@email.com</p>

<p>💬 Discord: YourDiscordName</p>

<p>🌐 Website: yourwebsite.com</p>

<p>🕒 Support Hours: Monday - Friday | 9:00 AM - 5:00 PM</p>

</div>

</div>

</div>

<footer>

© 2026 Your Website

</footer>

<script>
document.querySelector("form").addEventListener("submit", function(e){

e.preventDefault();

alert("Thanks for contacting us! (This is a template, so no message is actually sent.)");

});
</script>

</body>
</html>
